{
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/build",
  "directoryListing": false,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "public": true,
  "env": {
    "REACT_APP_ENVIRONMENT": "production"
  }
}

